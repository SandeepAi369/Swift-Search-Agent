# ═══════════════════════════════════════════════════════════
# Swift Search Agent v2.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All variables are OPTIONAL — sensible defaults are built-in.

# ─── Search Engine Configuration ───
# Mode: "unified" (default) or "separate"
SEARCH_MODE=unified

# RAM tier override: "micro", "small", "medium", "large" (auto-detected by default)
# SEARCH_RAM_TIER=auto

# Extraction quality: "high", "medium", "fast" (tier-based default)
# SEARCH_QUALITY=medium

# Early termination: stop when N% of context buffer is filled (0.0–1.0)
# SEARCH_EARLY_STOP=0.75

# ─── LLM Provider ───
# API endpoint (OpenAI-compatible)
LLM_API_URL=https://api.cerebras.ai/v1/chat/completions

# Model name
LLM_MODEL=llama-3.3-70b

# Max tokens for LLM response
LLM_MAX_TOKENS=4096

# Temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# ─── SearxNG Instances ───
# Comma-separated list of SearxNG instances (search_ultra.py)
# SEARXNG_INSTANCES=https://search.ononoki.org,https://searx.be,https://search.sapti.me

# ─── Server ───
PORT=8000
