# ════════════════════════════════════════════════════
# Swift Search Agent v2.0 — Environment Variables
# ════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# All variables are OPTIONAL — sensible defaults apply.

# ─── SearxNG Endpoint ───
# Your private SearxNG instance (local, HF Space, VPS, etc.)
SEARXNG_URL=http://localhost:8080

# ─── Engine Selection ───
# Datacenter-friendly engines — NO Google, NO Bing
# These work reliably from any server without CAPTCHA blocks
SEARXNG_ENGINES=duckduckgo,brave,yahoo,qwant,mojeek

# ─── Search Mode ───
# "unified" = recommended single-file engine (default)
SEARCH_MODE=unified

# ─── RAM Tier Override ───
# Auto-detected by default. Override: micro, small, medium, large
# SEARCH_RAM_TIER=large

# ─── Extraction Quality ───
# Overrides the tier default. Options: high, medium, fast
# SEARCH_QUALITY=high

# ─── Early Stop ───
# Stop scraping when this % of context buffer is filled (0.0–1.0)
# SEARCH_EARLY_STOP=0.75

# ─── Server ───
PORT=8000
